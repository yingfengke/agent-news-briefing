# 忽略本地工作目录
.workbuddy/
.codebuddy/

# Python 缓存
__pycache__/
*.pyc

# 忽略环境变量文件（⚠️ 含真实 API Key 和邮箱授权码，切勿上传）
.env

# IDE 配置
.idea/
agent_news_briefing/.idea/

# 忽略运行时生成的中间文件
web/email_content.html
email_content.txt

# 忽略所有 JSON 状态文件（含运行时生成的 .last_style.json）
*.json
!src/config/trivia.json

# 忽略 JS 文件（仅用于旧邮件检查，已弃用）
*.js

# 忽略所有 Markdown 文档，仅保留 README.md
*.md
!README.md

# 忽略临时测试文件
test.py

# 日志文件
logs/
